# Telegram fallback (required for fallback delivery)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Webhook port — MCP server listens here for check.js to POST due reminders
WEBHOOK_PORT=8787

# HQ Bus (optional — for multi-session setups with a message broker)
# Leave empty to disable bus delivery; webhook + telegram will be used.
BUS_BROKER_URL=
BUS_TARGET_SESSION=

# How long to wait for Claude to acknowledge before Telegram fallback (minutes)
ACK_TIMEOUT_MINUTES=2

# Timezone for parsing relative times (e.g., "5pm", "tomorrow 9am")
# Auto-detects from your system if not set. Override if needed.
# TIMEZONE=America/New_York
